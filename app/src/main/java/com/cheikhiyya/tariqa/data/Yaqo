    YaqoutaVerse(59, "وأي مــــعــــد لــلـــذنـــوب ومــحـــوهـــا == أشــد مــن إســـم ذي الـصـفـات الجلـيـلـة"),
    YaqoutaVerse(60, "ومـا الـحـج والجـهـاد مــن غـيـر فرضـنـا == بأفـضـل مـــن ذكـــر الأسـمــاء العظـيـمـة"),
    YaqoutaVerse(61, "بــل الـذكـر أولـــى ثم أقوى لا سـيـمـا == إذا إستـشـعـر الـقـلـب الـنعـوت الحـميـدة"),
    YaqoutaVerse(62, "بــــذا صــــدع الـمـخـتـار أعــنــي نـبـيـنـا == وصــح بنـقـل فـــي الآثـــار الصحـيـحـة"),
    YaqoutaVerse(63, "وأي ســـلـــوك كـــامـــل دون صــحــبـــة == وأي إهـــتـــداء شـــامـــل دون مــنــحـــة"),
    YaqoutaVerse(64, "وأي طــريـــق راشـــــد غــيـــر رشــدنـــا == وأي إهـتـمـام الـوقــت مـــن غـيــر هـمــة"),
    YaqoutaVerse(65, "فـصــدق فــــإن الــصــدق أرفــــع رتــبــة == لـمـن يبتـغـي وصـولا فإحـفـظ مقـالـة"),
    YaqoutaVerse(66, "لـقــد شـهــد الـمـولـى بــأنــي نصـيـحـكـم == وأنــــي عــلــى نــصــح جــديــر بـخـبــرة"),
    YaqoutaVerse(67, "فــــوا أســفــا لــتـــارك حــبـــل عـهــدنــا == عــمـــي وصـــــم وإرتــــــد بـالـقـطـيـعـة"),
    YaqoutaVerse(68, "ويـــا خـيـبـة الـمـشـغـول عــنــا بـلـهــوه == وأضــحــى بـعـيـدنــا ســريـــع الـنــدامــة"),
    YaqoutaVerse(69, "ويــــا حــســرة الــذيــن نــــاؤوا بـبـعـدنــا == إلــــى أن تـجـرعــوا كـــــؤوس الـمـنـيــة"),
    YaqoutaVerse(70, "سيسقـطـوا فــي أيــدي الـخـوالـف بـعـدنـا == لـمــا فــرطــوا فــــي أخــذهــم للـطـريـقـة"),
    YaqoutaVerse(71, "ومــا أقـبـح التسـويـف عــن قــرب بـابـنـا == ومـــا أحـســن التشـمـيـر قـبــل الإفــاتــة"),
    YaqoutaVerse(72, "فـــأنــــى لــبــطـــال يـــظــــل مــثــبــطــا == حـلـيـف الـكــرى غـــرا بـطــيء الإفــاقــة"),
    YaqoutaVerse(73, "يـنــال مـقــام الـقــوم أو يــــدرك الـمـنــى == ويـفـهـم عـنـهـم وهـــو صـاحــب سـكــرة"),
    YaqoutaVerse(74, "أم كــيــف رضــــاء الله يــدركـــه الـــــذي == يـســاخــط ربـــــه ويــرضـــي الـخـلـيـقـة"),
    YaqoutaVerse(75, "أم كـيــف لمـغـتـاب الـــورى ذي نـمـيـمـة == يـمــوت شـهـيـدا أو عــلــى خــيــر مــلــة"),
    YaqoutaVerse(76, "أم كــيــف لـمـســرف الـطـعــام وشــربــه == يــــــذوق مـــذاقـــا أو يـــفـــوز بــشــمــة"),
    YaqoutaVerse(77, "كـــذا مـــن عـــرف بالـفـسـوق ونـحـوهـا == يــجـــازى بـفـعــلــه الـقـبــيــح ولــعــنــة"),
    YaqoutaVerse(78, "فـلـم يمتـثـل أمـــرا ولـــم يجـتـنـب نـهـيـا == ولـــم يـذكــر الـمـولـى خـبـيـث الـسـريـرة"),
    YaqoutaVerse(79, "حـريــص عــلـــى دنــيـــاه لاه مــكــثــر == مــنــاع لـلـخــيــر مــعــتــد ذو عــتــلــة"),
    YaqoutaVerse(80, "فـكــيــف يـــكـــون لـلـعــلــوم مـنـاســبــا == أخــو الكـسـل والتفـريـط فــي خـيـر خـلـة"),
    YaqoutaVerse(81, "اذا مــا امتـطـى الـقــوم الـدجــى للتـهـجـد == وحـــــازوا مـــقـــام قـــربـــه بـالـمــزيــة"),
    YaqoutaVerse(82, "بمقـعـد صـــدق فـــازوا والـرتــب الـعـلـى == وأســمــى فــراديــس الـجـنــان الـرفـيـعـة"),
    YaqoutaVerse(83, "فـأعــلــى مــقـــام الـعـارفــيــن بــربــهــم == رضــــوان الإلــــه ثـــــم زائـــــد نــظـــرة"),
    YaqoutaVerse(84, "وذلـــــــك كـــلــــه بــفـــضـــل إلــهـــنـــا == يـــنـــال بـــمــــن لا بـــكــــد و حــيــلـــة"),
    YaqoutaVerse(85, "وأمــــا أســيــر ذنــبـــه يـــــوم حــشـــره == فـهــالــك إن لـــــم يـنـجـيـنــه بــرحــمــة"),
    YaqoutaVerse(86, "دعــــوت إلــــى بــــاب الـكـريــم عــبــاده == دعــاء مــأذون لــم يـــزل عـــن بـصـيـرة"),
    YaqoutaVerse(87, "وقـــد جـــاء\" ولـتـكــن\" بـمحـكـم ذكــــره == إلــى:\" المفلـحـون.\" أيــن أهــل الإجـابـة"),
    YaqoutaVerse(88, "فــكــن مـقــتــد بــنـــا وثـــــق بـكـلامـنــا == وجــــد فــــي سـيـرنــا تــفـــز بـالــمــودة"),
    YaqoutaVerse(89, "فـإنـنــي عــبــد الــقـــادر بـــــن مـحــمــد == سـلـيـل أبـــي الـربـيـع نـجــل الـسـمـاحـة"),
    YaqoutaVerse(90, "ولا فــخــر غــيــر أنــــي عــبــد لــقـــادر == وأحـمــد تـــاج الـرســل أقـــوى وسـيـلــة"),
    YaqoutaVerse(91, "فـبـالإتـبـاع نـلــنــا مــرتـبة الـعــلــى == فـــبالله مـــا حـدنــا عـــن شـــرع وسـنــة"),
    YaqoutaVerse(92, "ومــنـــذ عـقـلــنــا ســــــدد الله سـعـيــنــا == ومـازلـنــا مـقـتـفـيـن نــهـــج الـشـريـعــة"),
    YaqoutaVerse(93, "ولا تـسـمـعــن قــــــول عــــــاد مــعــانــد == حــســود لـفـضــل الله بـــــادي الـتـعـنــت"),
    YaqoutaVerse(94, "ومـــن يـنـسـبـن إلـيـنــا غــيــر مـقـولـنـا == يــصــبــه بـــحـــول الله أكـــبـــر عـــلـــة"),
    YaqoutaVerse(95, "ومـــوت عــلــى خــــلاف ديــــن مـحـمــد == ويـبـتـلـيــه الــمــولــى بــفــقــر وقـــلـــة"),
    YaqoutaVerse(96, "وبـــطـــش وشــــــدة إنــتــقــام وذلـــــــة == ويــردعـــه ردعـــــا ســريـــع الإجـــابـــة"),
    YaqoutaVerse(97, "بـلـعــن الإلــــه بــــاء مــــن رمى نـسـبـنـا == عــنــادا إلــــى فــعـــل نـكــيــر وبــدعـــة"),
    YaqoutaVerse(98, "كــــذاك الــــذي يــرمــي كــريــم جـنـابـنـا == ويــنــســب قـــدرنـــا لأقـــبـــح ســـيـــرة"),
    YaqoutaVerse(99, "فـكـيـف وبـإســم الـحــق نـهــج طـريـقـنـا == يــعــود إلــــى ضــــلال أهـــــل الـدنــاءة"),
    YaqoutaVerse(100, "بــدايــتـــهـــا لـلـغــافــلــيــن بـــتـــوبــــة == وأشــراطــهـــا مــحــصـــورة بـالـتـثــبــت"),
    YaqoutaVerse(101, "ونــصـــح لـــديـــن الله ثــــــم رســـولـــه == وخــاصــتـــه والـمـؤمـنــيــن بــجــمــلــة"),
    YaqoutaVerse(102, "وتـطـيـيــب لـقــمــة وتـعـظـيــم حــرمـــة == وشـــكـــر لـنـعــمــة ورفـــــــع لــهــمـــة"),
    YaqoutaVerse(103, "قـواعــدهــا شـــــوق وعــيـــن يـقـيـنـهــا == مـحـبــة جــــد الـسـيــر دأبــــا لـحــضــرة"),
    YaqoutaVerse(104, "وكـــــــف الأذى وحــمـــلـــه والتــصـــبـــر == ولا تـهـمـل الـرضــى بــأدنــى المـصـيـبـة"),
    YaqoutaVerse(105, "وزهـــــد وتـسـلــيــم وعـــفـــو وعـــفـــة == وتـفــويــض أمـــــر والـشــهــود لـمــنــة"),
    YaqoutaVerse(106, "وجــــــد قــــــوي واجــتــهــاد مـــوافـــق == وصـــوم وسـهــر ثـــم صـمــت وعــزلــة"),
    YaqoutaVerse(107, "وحــــزن ودمــــع ســاكــب ثــــم لــوعــة == وشــغــف قــلـــوب الـوالـهـيــن بــزفـــرة"),
    YaqoutaVerse(108, "نـهـايـتــهــا شــــــــم وذوق شــرابـــهـــا == بــــه ري خــمـــر ثـــــم ســكـــر بـغـيـبــة"),
    YaqoutaVerse(109, "وأمـطـارهــا فـــكـــر وذكــــــر وعـــبـــرة == ومــحـــو ذواتــهـــم في الـــذات الـعـظـيـمـة"),
    YaqoutaVerse(110, "ومــن بـعـد غـيـم جــاء صـحـو سـمـاءهـا == بــإشــراق شــمــس بـالـمـعـارف حــفــت"),
    YaqoutaVerse(111, "فـجـذب لـــه عـــزم انـتـهـى دون حـاجــب == إلـــى حــضــرة الــقــدوس زج بـسـرعــة"),
    YaqoutaVerse(112, "وحـــال لـهــا حـــوى الأصـــول بـأسـرهـا == طـريــقــة أســــــلاف بــيــضــاء نــقــيــة"),
    YaqoutaVerse(113, "فــهــذي فـصـولـهــا وشـــــرط كـمـالـهــا == مــنــوط بـعــلــم ثـــــم حــلـــم وحـكــمــة"),
    YaqoutaVerse(114, "لهـا الجمـع جمـع الجـمـع جـمـع إتحـادهـا == أصـــول لـهــا شـهــود فـــي كـــل لـمـحـة"),
    YaqoutaVerse(115, "فــأولــهـــا ولــــــــي ثــــــــم نـقـيــبــهــا == نـجـيــب كــــذا الأبــــدال فــاقــوا بـرتـبــة"),
    YaqoutaVerse(116, "عـمـادهــم الأخــيــار أوتــادهـــم حــبـــوا == بخاصـيـة المـولـى هــم أهــل الخصـاصـة"),
    YaqoutaVerse(117, "وغــوث إستيـغـاث ثــم جــرس علـومـهـا == وقــطــب لــــه أعــلــى مــقــام الــولايـــة"),
    YaqoutaVerse(118, "فـشـيــخ الـشـيــوخ ذاك شــيــخ زمـانـنــا == إلـيــه إنـتـهـت فـنــون هــــذي الـطـريـقـة"),
    YaqoutaVerse(119, "فمـن شيخنـا عــن شيـخـه عــن شيـوخـه == تسـلـسـلـت الأشــيـــاخ أهـــــل الــعنايـــة"),
    YaqoutaVerse(120, "كــذا نسـبـة الأبــرار مــع صـفــوة الـمــلا == لــهــا شــــرف يـنــمــى لــعـــز ورفــعـــة"),
    YaqoutaVerse(121, "فـمــن قـــدوة عـــلا إلـــى نـخـبــة ســمــا == ومــن صـفـوة رقـــى لأسـمــا الـخـلاصـة"),
    YaqoutaVerse(122, "وتـلـكـم مـــن بــحــر الـنـبــوءة أنـشـئــت == ومــنــه إسـتـمــدت فــحــول الــدرايـــة"),
    YaqoutaVerse(123, "عـلـيـك بـهــم فـــي كـــل شـــأن تــشــاؤه == تـوســل بــهــم تــنــل ســريــع الإجــابــة"),
    YaqoutaVerse(124, "فـخـذهــم بـنـظــم واحــــدا بــعــد واحــــد == عـلـيـهـم مــــن الإلـــــه أزكـــــى تـحــيــة"),
    YaqoutaVerse(125, "فـأولـهـم فـــي الـذكــر شـمــس وجـودنــا == وقــطـــب نــهــى عـلـومـنــا الـلـدنــيــة"),
    YaqoutaVerse(126, "إلـيــه انـتـهـت رئـاســة الـقــوم فـارتـقـى == علـى صـهـوات المـجـد مــن غـيـر مـريـة"),
    YaqoutaVerse(127, "أبــــو عـبـيــد الإلــــه يـسـمــى مـحــمــدا == إلــى عبـيـد الرحـمـن يـعـزى فــي نسـبـة"),
    YaqoutaVerse(128, "عـلــيــه ســـــلام الله مــــــا ذر شــــــارق == ومـــا غــــنى طــيــر بـالـلـغـات الحـنـيـنـة"),
    YaqoutaVerse(129, "فعـنـه أخـذنـا أعـنـي عـــن قـمــر الـدجــى == ورثـنــا طــريــق الــقــوم دون إسـتـرابــة"),
    YaqoutaVerse(130, "فبالراشـدي إقتـدى وعــن زروق إهـتـدى == عـــن الحـضـرمـي ثـــم شــيــخ الـقـرافــة"),
    YaqoutaVerse(131, "عـــن ابـــن عـطــاء الله بــحــر عـلـومـنـا == عــن المـرتـضـى الـمـرسـي أحـمــد حـلــة"),
    YaqoutaVerse(132, "مــعـــارف مــنـــه لــلـــورى ومـــواهـــب == فــحــاز بــهــا مــجــد الــعــلى والـجـلالــة"),
    YaqoutaVerse(133, "إلـى الشاذلـي السامـي أبـي الحسـن الـذي == بحـوز الكمـال أضحـى بحـر الحقيقـة"),
    YaqoutaVerse(134, "عــن ابــن مشـيـش قـطـب دائــرة الـعـلـى == عـبـيــد الــســلام ذي الـعـلــوم الـرفـيـعــة"),
    YaqoutaVerse(135, "عــن المـدنـي الـمـرضـي غـــوث زمـانــه == أبــــي يــزيــد الـنـحـريـر تــــاج الأحــبــة"),
    YaqoutaVerse(136, "عـــن الـشـيـخ شـيـخـه مـريــد شعـيـبـهـم == أبــــي أحــمــد الـسـنــي بــــدر الـسـعــادة"),
    YaqoutaVerse(137, "عــن الـسـيــد الـــــذي أقـــــر بـفـضـلــه == أئـمـة مـــن مـضــى مـــن أهـــل الـولايــة"),
    YaqoutaVerse(138, "ومـــــــع ذاك أن الله أشـــهــــر ذكــــــــره == كشـهـرة هــذي الشـمـس مــن كــل بـلــدة"),
    YaqoutaVerse(139, "أخــي لـــذ بـــه وأصـــغ سـمـعـا لإسـمــه == أبــــي مــديــن إمــــام هــــذي الـطـريـقـة"),
    YaqoutaVerse(140, "لـقـد أخــذ الأســرار عـــن قـطــب غـربـنـا == الإمـــام أبـــي يــعــزى نــــور الـبـصـيـرة"),
    YaqoutaVerse(141, "عـن السيـد الأسـنـى الهـمـام الــذي سـمـا == أبــي الحـسـن إبــن حـرزهـم ذي الإغـاثـة"),
    YaqoutaVerse(142, "عــن الشـيـخ فـخـر الـديـن ناهـيـك فـخـره == أبـــي بـكـرهــم يــحــي ســــراج الأئــمــة"),
    YaqoutaVerse(143, "عــن الشـيـخ شـيـخ الـكـل ســـر هـداتـهـم == إمــــــام كــفــيــاض الــبــحــور وقدوة"),
    YaqoutaVerse(144, "بـــه يستـغـيـث الــكــل شــرقــا ومـغـربــا == أبـــي حـامــد الـغـزالــي عــيــن الـعـنـايـة"),
    YaqoutaVerse(145, "عــــن الـسـيــد أبــــي الـمـعـالــي لأنـــــه == إمــــام إليه يـنـتـهـي فــــي الـفــراســة"),
    YaqoutaVerse(146, "عن الشيخ شمس الدين ذي النصح للورى == أبــــي طــالــب الـمـكــي نــــور الــولايــة"),
    YaqoutaVerse(147, "عــن السـيـد المـرضـي فــي كـــل سـيــرة == الإمــام الـجـريـري ذي الـنـهـى والنـهـايـة"),
    YaqoutaVerse(148, "عــن الـشـيـخ تـــاج العـارفـيـن رئيـسـهـم == أبـــي الـقـاســم الـجـنـيـد روح الـمـجــادة"),
    YaqoutaVerse(149, "عـن السـري السقطـي نجـل مغلـس == عـن مـعـروف الكـرخي نـجــم الـدلالة"),
    YaqoutaVerse(150, "إلــى داوود الطـائـي الــذي فــاض عـلـمـه == عــــن الـعـجـمـي حبـيـبـهـم ذي الإنــابــة"),
    YaqoutaVerse(151, "إلى الحسـن البصـري الــذي فــاق نــوره == نــجــوم الــدجــى ونــــور كــــل مـنــيــرة"),
    YaqoutaVerse(152, "إلــــى ســيــف ربــنـــا الـمـهـنــد لـلــعــدا == وبـــــاب مــديــنــة الــعــلــوم الـجـلـيـلــة"),
    YaqoutaVerse(153, "أبــــي الـحـســن عــلــي صــهــر نـبـيـنــا == عـلـيــه رضــــاء الله فــــي كــــل لـمـحــة"),
    YaqoutaVerse(154, "إلــى تــاج مـــن وافـــى القـيـامـة جـمـلـة == ونــوره عـيـن الـكـون مــن دون مـريــة"),
    YaqoutaVerse(155, "محمـد الـهــادي إلـــى الـنــاس رحـمــة == ومــعـــدن أســـــرار وعـنــصــر نــعــمــة"),
    YaqoutaVerse(156, "عــلــيــه صــــــلاة الله ثــــــم ســـلامــــه == تـــدوم دوام الـمـلــك فــــي كــــل لـحـظــة"),
    YaqoutaVerse(157, "فـعـن جبـريـل الأمـيـن عــن إسرافـيـل قــد == تـلـقـاها مـــن الـلــوح مـحـفـوظ الأمـانــة"),
    YaqoutaVerse(158, "عـــن الـقـلـم الـمـأمــور بـالـخــط بالــــذي == قـــد كـــان ومـــا يـكــون مــــن كــــل ذرة"),
    YaqoutaVerse(159, "وكـــــــل بـــأمــــر ربـــنــــا وقــضــائـــه == فـســلــم وصــدق وأحــكـــمن بــصــحــة"),
    YaqoutaVerse(160, "وإيــــاك والـتـعـنـيـت والـحــســد الـــــذي == يـنـافـي الـكـمـال عـــن صـمـيـم الـعـقـيـدة"),
    YaqoutaVerse(161, "فـــــإن مــواهـــب الــكــريــم تـعـاظــمــت == لـديـنـا مـــن غـيــر حـــول مـنــا و قـــوة"),
    YaqoutaVerse(162, "وإن قــلـــت مــاالـــذي أنــالـــك فــضــلــه == فــفــضــل الإلــــــه لا يـــنـــال بـحــيــلــة"),
    YaqoutaVerse(163, "عـلـى أنـــي للتقـصـيـر والـعـجـز حيـثـمـا == حـلـلــت مــلازمــا وفــــي كـــــل حــالـــة"),
    YaqoutaVerse(164, "ولـسـت بـــذي نـحــو ولا عـــروض لـمــا == يرومــه مــــن قـريـضـنــا ذو الــدرايـــة"),
    YaqoutaVerse(165, "فــعـــذرا لــمـــن رام إنـتــقــاد ظــاهــرنــا == فـلــم نــعــد عــــن أوصـافـنــا الـبـشـريـة"),
    YaqoutaVerse(166, "ومــــن رأى مــــن عـيـوبـنـا فلـيـداركـهـا == بـحــلــم وليصـلـحـنـهـا بــعـــد الـتـثـبــت"),
    YaqoutaVerse(167, "ولــــولا الـكـريــم جــــاد مــنــا بـفـضـلــه == لــمــا فـهمنـــا هذي الـعــلــوم بـقــولــة"),
    YaqoutaVerse(168, "ولـكــن ســتــر من مـسـاوئـنـا جـمـلــة == وأظـهــر مـــا بــــه الـنـفــوس إطـمـأنــت"),
    YaqoutaVerse(169, "لــــه الـحـمــد أولا وآخــــرا مـــثل مــــا == لـه الشكـر عمــا أســداه مــن فضيـلـة"),
    YaqoutaVerse(170, "قــد إنتهـى بـنـا الـقـول نظمـا في كــل مـا == نـحـاول مــن تحـصـيـل جـمــع القـصـيـدة"),
    YaqoutaVerse(171, "وسميـتـهـا الـيـاقـوت رفـعــا لــقــدر مــــا == تسـلـسـل فــيــها مــــن أشــيــاخ عــديــدة"),
    YaqoutaVerse(172, "مــعـــرفـــة لــشــأنــهـــم وطــريــقــهـــم == وأسـمـائـهـم ذوي الأحـــــوال الـشـريـفــة"),
    YaqoutaVerse(173, "عليـهـم رضــاء رب الـعـرش بـمــلء مـــا == أحــــاط بــــه عـلــمــا وأزكـــــى تـحــيــة"),
    YaqoutaVerse(174, "وأهـــدي الــصــلاة والــســلام مـسـرمــدا == عـلــى كـــل رســــل الله أهــــل الـنـبــوءة"),
    YaqoutaVerse(175, "وأضـعـافـهــا عــلـــى الــنــبــي مــحــمــد == إمــــام الــرســل الـمـجـتـبـى بـالـوسـيـلـة"),
    YaqoutaVerse(176, "هـــو الـنـبـي المـبـعـوث لـلـخـلـق كـلـهــم == وحــامـــل اللـــــواء كـــامـــل الـشـفــاعــة"),
    YaqoutaVerse(177, "وآلـــه والأصــحــاب ثــــم جـمـيــع مــــن == قـفـا نهـجـه الـقـويـم فـــي كـــل وجـهــة"),
    YaqoutaVerse(178, "صــــلاة تــمــلأ الــكــون عـــــدد وزنـــــه == كـذاك مــا فــوق الـفـوق وأسـفـل ظلـمـة"),)

